# Copy to .env and fill in ( .env is gitignored — never commit real tokens )
# Use quotes — OpnForm tokens often contain |
COLEEBRI_OPNFORM_TOKEN=''
COLEEBRI_OPNFORM_API_BASE=https://app.coleebri.eu/api
COLEEBRI_OPNFORM_PUBLIC_BASE=https://app.coleebri.eu
COLEEBRI_OPNFORM_WORKSPACE_ID=1
COLEEBRI_OPNFORM_ENQUIRY_SLUG=
COLEEBRI_OPNFORM_ENQUIRY_ID=

# WordPress REST sync (scripts/sync-wp-tests.mjs)
COLEEBRI_WP_URL=https://health.coleebri.com
COLEEBRI_WP_USER=
COLEEBRI_WP_APP_PASSWORD=''

# Catalogue public URL (deep links + Elementor CTAs)
COLEEBRI_CATALOGUE_BASE=https://health.coleebri.com/catalogue/
